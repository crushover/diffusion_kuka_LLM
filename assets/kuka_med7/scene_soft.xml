
<!-- kuka med 7机械臂 / 棕色正方体模拟的实验桌 / 正方体柔性体 -->


<mujoco model="kuka_med7_soft_interaction">
  <include file="med7.xml"/>

  <option timestep="0.0005" solver="Newton" tolerance="1e-6" integrator="implicitfast"/>

  <statistic center="0.5 0 0.5" extent="1.5"/>
  
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
    <map stiffness="100" stiffnessrot="500"/> 
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table_mat" rgba="0.5 0.3 0.1 1" specular="0.2" shininess="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="table" pos="0.7 0 0.2">
      <geom type="box" size="0.25 0.25 0.2" material="table_mat" friction="1 0.005 0.0001"/>
    </body>

    <flexcomp name="sponge_box" type="grid" count="6 6 6" spacing="0.04 0.04 0.04" 
              pos="0.7 0 0.55" radius="0.003" rgba="0 0.8 0.8 1" dim="3" mass="0.5">
      <contact condim="3" solref="0.02 1" solimp=".95 .99 .0001" selfcollide="none"/>
      
      <!-- 控制了柔性体内部网格的粘滞阻力 -->
      <edge damping="2"/>
      <elasticity young="1e4" poisson="0.3"/> 
    </flexcomp>

  </worldbody>
</mujoco>